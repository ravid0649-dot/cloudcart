APP_NAME=CloudCart
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=replace-with-long-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/cloudcart
CORS_ORIGINS=http://localhost:8000,https://your-frontend-domain.onrender.com
UPLOADS_DIR=app/static/uploads
MAX_UPLOAD_SIZE_MB=5
